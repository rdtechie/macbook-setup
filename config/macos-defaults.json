{
  "description": "Documented macOS defaults applied by scripts/apply-macos-defaults.sh.",
  "settings": [
    {
      "domain": "com.apple.screencapture",
      "key": "location",
      "value": "$HOME/Pictures/Screenshots",
      "reason": "Keep screenshots out of Desktop."
    },
    {
      "domain": "com.apple.screencapture",
      "key": "type",
      "value": "png",
      "reason": "Use a broadly compatible screenshot format."
    },
    {
      "domain": "NSGlobalDomain",
      "key": "AppleShowAllExtensions",
      "value": true,
      "reason": "Show file extensions for safer development workflows."
    },
    {
      "domain": "com.apple.finder",
      "key": "ShowPathbar",
      "value": true,
      "reason": "Improve Finder navigation."
    },
    {
      "domain": "com.apple.finder",
      "key": "ShowStatusBar",
      "value": true,
      "reason": "Show counts and free space in Finder."
    },
    {
      "domain": "com.apple.finder",
      "key": "FXDefaultSearchScope",
      "value": "SCcf",
      "reason": "Search the current folder by default."
    },
    {
      "domain": "com.apple.finder",
      "key": "_FXSortFoldersFirst",
      "value": true,
      "reason": "Keep folder listings predictable."
    },
    {
      "domain": "com.apple.finder",
      "key": "FXPreferredViewStyle",
      "value": "Nlsv",
      "reason": "Prefer list view for file operations."
    },
    {
      "domain": "com.apple.desktopservices",
      "key": "DSDontWriteNetworkStores",
      "value": true,
      "reason": "Avoid .DS_Store files on network volumes."
    },
    {
      "domain": "com.apple.desktopservices",
      "key": "DSDontWriteUSBStores",
      "value": true,
      "reason": "Avoid .DS_Store files on removable volumes."
    },
    {
      "domain": "com.apple.dock",
      "key": "autohide",
      "value": true,
      "reason": "Auto-hide the Dock to reclaim vertical screen space."
    },
    {
      "domain": "com.apple.dock",
      "key": "tilesize",
      "value": 24,
      "reason": "Half the default Dock icon size (48 → 24) for a less obtrusive Dock."
    },
    {
      "domain": "com.apple.dock",
      "key": "persistent-apps",
      "value": [],
      "reason": "Remove all pinned app icons from the Dock; Finder is always present separately."
    },
    {
      "domain": "NSGlobalDomain",
      "key": "KeyRepeat",
      "value": 2,
      "reason": "Fastest key-repeat rate (macOS minimum)."
    },
    {
      "domain": "NSGlobalDomain",
      "key": "InitialKeyRepeat",
      "value": 25,
      "reason": "Initial key-repeat delay at roughly 25% of the slider range (fast end)."
    }
  ]
}
